// Firestore Security Rules
// Paste vào: Firebase Console → Firestore Database → Rules → Replace toàn bộ → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Mỗi user chỉ đọc/ghi document trong subcollection của mình
    match /users/{userId}/decks/{deckId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Mặc định cấm tất cả (defense in depth)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
